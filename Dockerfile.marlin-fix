FROM vllm-node-jasl-fix:latest

# Mixed backend: 42 layers Marlin + layer 42 DeepGEMM fallback
# Fixes: TP padding offset, swiglu_limit, clamp_limit, workspace alias,
#         normal oracle (no forced DEEPGEMM), VLLM_MXFP4_MARLIN_DEEPGEMM_LAYERS support

COPY spark-vllm-docker/vllm-sm120/vllm-sm120/vllm/model_executor/layers/quantization/mxfp4.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/quantization/mxfp4.py

COPY spark-vllm-docker/vllm-sm120/vllm-sm120/vllm/model_executor/layers/fused_moe/oracle/mxfp4.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/oracle/mxfp4.py

COPY spark-vllm-docker/vllm-sm120/vllm-sm120/vllm/model_executor/layers/fused_moe/layer.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/layer.py

COPY spark-vllm-docker/vllm-sm120/vllm-sm120/vllm/model_executor/layers/fused_moe/fused_marlin_moe.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/fused_marlin_moe.py
